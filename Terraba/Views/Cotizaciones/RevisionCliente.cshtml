@{
    ViewData["Title"] = "Revisar Cotización";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="fade-in">

    <div class="row justify-content-center">
        <div class="col-md-7">

            <div class="card shadow p-4">

                <!-- HEADER EMPRESA -->
                <div class="text-center mb-3">
                    <h3 class="text-success fw-bold">
                        Térraba Comunicaciones
                    </h3>
                    <small class="text-muted">WCW SA</small>
                </div>

                <hr>

                <!-- DETALLE -->
                <h5 class="mb-3">Detalle de la Cotización</h5>

                <p><strong>Cliente:</strong> Juan Pérez</p>
                <p><strong>Servicio:</strong> Publicidad en Redes Sociales</p>
                <p><strong>Duración:</strong> 5 días</p>
                <p><strong>Alcance:</strong> Nacional</p>
                <p><strong>Diseño:</strong> Premium</p>

                <hr>

                <!-- TOTAL -->
                <h4 class="text-success text-end">
                    Total: $950
                </h4>

                <!-- ACCIONES -->
                <div class="d-flex justify-content-end gap-2 mt-4">

                    <button class="btn btn-success" onclick="aprobar()">
                        <i class="bi bi-check-circle"></i> Aprobar
                    </button>

                    <button class="btn btn-danger" onclick="rechazar()">
                        <i class="bi bi-x-circle"></i> Rechazar
                    </button>

                </div>

                <!-- RESULTADO -->
                <div id="resultado" class="mt-3 text-center"></div>

            </div>

        </div>
    </div>

</div>

<script>
    function aprobar() {
        document.getElementById("resultado").innerHTML =
            '<div class="alert alert-success">✔ Cotización aprobada</div>';

        mostrarNotificacion("Cotización aprobada", "success");
    }

    function rechazar() {
        document.getElementById("resultado").innerHTML =
            '<div class="alert alert-danger">✖ Cotización rechazada</div>';

        mostrarNotificacion("Cotización rechazada", "error");
    }
</script>