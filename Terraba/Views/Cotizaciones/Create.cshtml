@{
    ViewData["Title"] = "Nueva Cotización";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="fade-in">

    <h3 class="text-primary mb-4">
        <i class="bi bi-calculator"></i> Generar Cotización
    </h3>

    <div class="row">

        <!-- FORMULARIO -->
        <div class="col-md-6">

            <div class="card p-4 shadow">

                <div class="mb-3">
                    <label>Cliente</label>
                    <input type="text" class="form-control" placeholder="Nombre cliente">
                </div>

                <div class="mb-3">
                    <label>Tipo de Medio</label>
                    <select class="form-select" id="medio">
                        <option value="100">Redes Sociales ($100)</option>
                        <option value="300">Radio ($300)</option>
                        <option value="500">Televisión ($500)</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label>Duración (días)</label>
                    <input type="number" id="duracion" class="form-control" value="1">
                </div>

                <div class="mb-3">
                    <label>Alcance</label>
                    <select class="form-select" id="alcance">
                        <option value="1">Local</option>
                        <option value="1.5">Regional</option>
                        <option value="2">Nacional</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label>Diseño</label>
                    <select class="form-select" id="diseno">
                        <option value="50">Básico ($50)</option>
                        <option value="150">Premium ($150)</option>
                    </select>
                </div>

                <button class="btn btn-primary w-100" onclick="calcular()">
                    <i class="bi bi-calculator"></i> Calcular
                </button>

            </div>

        </div>

        <!-- RESULTADO -->
        <div class="col-md-6">

            <div class="card p-4 shadow">

                <h5 class="text-primary">Resumen</h5>
                <hr>

                <p>Medio: <span id="r_medio"></span></p>
                <p>Duración: <span id="r_duracion"></span></p>
                <p>Alcance: <span id="r_alcance"></span></p>
                <p>Diseño: <span id="r_diseno"></span></p>

                <hr>

                <h4 class="text-primary">
                    Total: $<span id="total">0</span>
                </h4>

            </div>

        </div>

    </div>

</div>

<script>
    function calcular() {

        let medio = document.getElementById("medio");
        let duracion = document.getElementById("duracion").value;
        let alcance = document.getElementById("alcance").value;
        let diseno = document.getElementById("diseno");

        let precioMedio = medio.value;
        let precioDiseno = diseno.value;

        let total = (precioMedio * duracion * alcance) + parseInt(precioDiseno);

        document.getElementById("total").innerText = total;

        document.getElementById("r_medio").innerText = medio.options[medio.selectedIndex].text;
        document.getElementById("r_duracion").innerText = duracion + " días";
        document.getElementById("r_alcance").innerText = alcance;
        document.getElementById("r_diseno").innerText = diseno.options[diseno.selectedIndex].text;
    }
</script>