@model IEnumerable<Terraba.Models.Cotizacion>

@{
    ViewData["Title"] = "Cotizaciones";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="fade-in">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h3 class="text-primary fw-bold mb-0">
                <i class="bi bi-file-earmark-text"></i> Cotizaciones
            </h3>
            <small class="text-secondary">Gestión de cotizaciones del sistema</small>
        </div>

        <a href="/Cotizaciones/Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Nueva Cotización
        </a>

    </div>

    <!-- TABLA -->
    <div class="card shadow-sm">

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-light">
                    <tr>
                        <th>Cliente</th>
                        <th>Fecha</th>
                        <th class="text-end">Total</th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null)
                    {
                        foreach (var cot in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@cot.Cliente</td>
                                <td class="text-secondary">@cot.Fecha.ToString("yyyy-MM-dd")</td>
                                <td class="text-end fw-bold">$@cot.Total.ToString("F2")</td>
                                <td>
                                    @{
                                        var badge = cot.Estado switch
                                        {
                                            "Borrador" => "bg-secondary",
                                            "Enviada" => "bg-primary",
                                            "Aprobada" => "bg-success",
                                            "Rechazada" => "bg-danger",
                                            "Convertida" => "bg-dark",
                                            _ => "bg-secondary"
                                        };
                                    }
                                    <span class="badge @badge">@cot.Estado</span>
                                </td>
                                <td class="text-end">
                                    <div class="btn-group">
                                        <a asp-action="Details" asp-route-id="@cot.Id" class="btn btn-outline-primary btn-sm"><i class="bi bi-eye"></i></a>
                                        <a asp-action="Edit" asp-route-id="@cot.Id" class="btn btn-outline-warning btn-sm"><i class="bi bi-pencil"></i></a>
                                        <form asp-action="Delete" method="post" style="display:inline">
                                            <input type="hidden" name="id" value="@cot.Id" />
                                            <button class="btn btn-outline-danger btn-sm" type="submit"><i class="bi bi-x-circle"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>
