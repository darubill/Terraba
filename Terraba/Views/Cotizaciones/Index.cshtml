@{
    ViewData["Title"] = "Cotizaciones";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="fade-in">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h3 class="text-primary fw-bold mb-0">
                <i class="bi bi-file-earmark-text"></i> Cotizaciones
            </h3>
            <small class="text-secondary">Gestión de cotizaciones del sistema</small>
        </div>

        <a href="/Cotizaciones/Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Nueva Cotización
        </a>

    </div>

    <!-- TABLA -->
    <div class="card shadow-sm">

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-light">
                    <tr>
                        <th>Cliente</th>
                        <th>Servicio</th>
                        <th class="text-end">Total</th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>

                <tbody>

                    <tr>

                        <td class="fw-semibold">Juan Pérez</td>

                        <td class="text-secondary">
                            Publicidad Digital
                        </td>

                        <td class="text-end fw-bold">$500</td>

                        <td>
                            <span class="badge bg-warning">Pendiente</span>
                        </td>

                        <!-- ACCIONES -->
                        <td class="text-end">

                            <div class="btn-group">

                                <a href="/Cotizaciones/Details" class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-eye"></i>
                                </a>

                                <a href="/Cotizaciones/Edit" class="btn btn-outline-warning btn-sm">
                                    <i class="bi bi-pencil"></i>
                                </a>

                                <button class="btn btn-outline-danger btn-sm">
                                    <i class="bi bi-x-circle"></i>
                                </button>

                            </div>

                        </td>

                    </tr>

                </tbody>

            </table>

        </div>

    </div>

</div>