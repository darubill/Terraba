@{
    ViewData["Title"] = "Notificaciones";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="fade-in">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h3 class="text-primary fw-bold mb-0">
                <i class="bi bi-bell"></i> Notificaciones
            </h3>
            <small class="text-secondary">Actividad reciente del sistema</small>
        </div>

        <button class="btn btn-outline-secondary" onclick="limpiar()">
            <i class="bi bi-trash"></i> Limpiar
        </button>

    </div>

    <!-- LISTA -->
    <div id="contenedorNotificaciones" class="d-flex flex-column gap-3">

        <!-- NOTIFICACIÓN ÉXITO -->
        <div class="card shadow-sm border-0">

            <div class="card-body d-flex justify-content-between align-items-center">

                <div class="d-flex align-items-center gap-3">

                    <!-- ICONO -->
                    <div class="bg-success bg-opacity-10 text-success p-3 rounded-circle">
                        <i class="bi bi-check-circle fs-5"></i>
                    </div>

                    <!-- TEXTO -->
                    <div>
                        <div class="fw-semibold">
                            Cotización aprobada
                        </div>
                        <small class="text-secondary">
                            Juan Pérez • Hace 2 minutos
                        </small>
                    </div>

                </div>

                <span class="badge bg-success">Aprobada</span>

            </div>

        </div>

        <!-- NOTIFICACIÓN ERROR -->
        <div class="card shadow-sm border-0">

            <div class="card-body d-flex justify-content-between align-items-center">

                <div class="d-flex align-items-center gap-3">

                    <!-- ICONO -->
                    <div class="bg-danger bg-opacity-10 text-danger p-3 rounded-circle">
                        <i class="bi bi-x-circle fs-5"></i>
                    </div>

                    <!-- TEXTO -->
                    <div>
                        <div class="fw-semibold">
                            Cotización rechazada
                        </div>
                        <small class="text-secondary">
                            Ana López • Hace 10 minutos
                        </small>
                    </div>

                </div>

                <span class="badge bg-danger">Rechazada</span>

            </div>

        </div>

    </div>

</div>

<script>
    function limpiar() {
        document.getElementById("contenedorNotificaciones").innerHTML = `

            <div class="card shadow-sm border-0 text-center p-4">

                <i class="bi bi-bell-slash fs-1 text-secondary mb-2"></i>

                <h6 class="text-secondary">Sin notificaciones</h6>

                <small class="text-muted">
                    No tienes actividad reciente
                </small>

            </div>

        `;
    }
</script>