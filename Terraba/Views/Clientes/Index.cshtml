@model IEnumerable<Terraba.Models.Cliente>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="fade-in">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h3 class="text-primary fw-bold mb-0">
                <i class="bi bi-people"></i> Clientes
            </h3>
            <small class="text-secondary">Gestión de clientes registrados</small>
        </div>

        <a href="/Clientes/Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Nuevo Cliente
        </a>

    </div>

    <!-- BUSCADOR -->
    <div class="card p-3 shadow-sm mb-3">

        <div class="input-group">
            <span class="input-group-text bg-white">
                <i class="bi bi-search"></i>
            </span>
            <input class="form-control" placeholder="Buscar por nombre o empresa...">
        </div>

    </div>

    <!-- TABLA -->
    <div class="card shadow-sm">

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-light">
                    <tr>
                        <th>Cliente</th>
                        <th>Empresa</th>
                        <th>Email</th>
                        <th>Teléfono</th>
                        <th>Creado</th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null)
                    {
                        foreach (var c in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@c.Nombre</td>
                                <td class="text-secondary">@c.Empresa</td>
                                <td class="text-secondary">@c.Email</td>
                                <td class="text-secondary">@c.Telefono</td>
                                <td class="text-secondary">@c.FechaCreacion.ToString("yyyy-MM-dd")</td>

                                <!-- ESTADO -->
                                <td>
                                    <span class="badge @(c.Estado=="Activo"?"bg-success":"bg-secondary")">@c.Estado</span>
                                </td>

                                <!-- ACCIONES -->
                                <td class="text-end">

                                    <div class="btn-group">

                                        <a asp-action="Details" asp-route-id="@c.Id" class="btn btn-outline-primary btn-sm">
                                            <i class="bi bi-eye"></i>
                                        </a>

                                        <a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-outline-warning btn-sm">
                                            <i class="bi bi-pencil"></i>
                                        </a>

                                        <form asp-action="Delete" method="post" style="display:inline">
                                            <input type="hidden" name="id" value="@c.Id" />
                                            <button class="btn btn-outline-danger btn-sm" type="submit"><i class="bi bi-x-circle"></i></button>
                                        </form>

                                    </div>

                                </td>
                            </tr>
                        }
                    }
                </tbody>

            </table>

        </div>

    </div>

</div>