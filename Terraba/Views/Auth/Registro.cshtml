
@model Terraba.Models.Usuario

@{
    ViewData["Title"] = "Registro de Usuario";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Registro - MediaReach</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="bg-light d-flex align-items-center justify-content-center" style="min-height:100vh">
    <div class="card shadow p-4" style="width:480px">
        <h4 class="mb-4 text-center">Crear cuenta</h4>

        @if (ViewBag.Exito != null)
        {
            <div class="alert alert-success">@ViewBag.Exito</div>
        }

        <form asp-action="Registro" method="post">
            <div class="mb-3">
                <label class="form-label">Nombre completo</label>
                <input asp-for="Nombre" class="form-control" placeholder="Ej. María López" />
                <span asp-validation-for="Nombre" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Correo electrónico</label>
                <input asp-for="Email" class="form-control" placeholder="correo@ejemplo.com" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Contraseña</label>
                <input asp-for="Contrasena" type="password" class="form-control" />
                <span asp-validation-for="Contrasena" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Rol</label>
                <select asp-for="Rol" class="form-select">
                    <option value="vendedor">Vendedor</option>
                    <option value="administrador">Administrador</option>
                </select>
            </div>
            <button type="submit" class="btn btn-primary w-100">Crear cuenta</button>
            <a asp-action="Login" class="btn btn-link w-100 mt-2">Ya tengo cuenta</a>
        </form>
    </div>
</body>
</html>
